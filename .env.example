# Django
SECRET_KEY=django-insecure-CHANGE-ME-to-a-real-secret-key
DEBUG=True

# Groq AI Co-Pilot (optional — AI features disabled without this)
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
