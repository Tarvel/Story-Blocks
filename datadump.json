ire_date": "2026-05-16T19:49:16.473Z"}}, {"model": "sessions.session", "pk": "lxg6yf1g79bzvracvwnf9b2ecmtgdcto", "fields": {"session_data": ".eJxVjMsOwiAQRf-FtSECw8ul-34DGWCQqoGktCvjv2uTLnR7zzn3xQJuaw3boCXMmV2YZKffLWJ6UNtBvmO7dZ56W5c58l3hBx186pme18P9O6g46rdGsiaq7GxSrpC2GUxxCn0sxitHPjp5hiw0FCvAkhYEgowBBOlNcsTeH-mzN54:1wJI2u:rtp2FFNqPZ8CcK8IuN_AiUEdz_k0Wjf7QcnQwI3Clys", "expire_date": "2026-05-16T21:38:44.723Z"}}, {"model": "engine.story", "pk": 1, "fields": {"title": "The Obsidian Spire", "description": "A high-stakes sci-fi mystery set in a dying orbital station. Every choice reshapes your fate.", "author": 1, "is_published": true, "story_uuid": "e2253900-3c62-4ee8-8a95-e27e412fbae8", "slug": "the-obsidian-spire", "access_password": null, "created_at": "2026-05-02T17:37:07.986Z", "updated_at": "2026-05-02T17:37:07.986Z"}}, {"model": "engine.story", "pk": 4, "fields": {"title": "Cyberpunk City", "description": "A gritty noir story in a neon-drenched future.", "author": 1, "is_published": true, "story_uuid": "82d86368-e616-4d16-a69f-55aad7058c89", "slug": "cyberpunk-city", "access_password": null, "created_at": "2026-05-02T19:29:56.913Z", "updated_at": "2026-05-02T19:29:56.913Z"}}, {"model": "engine.story", "pk": 5, "fields": {"title": "Tai's secret", "description": "what secrets does Tai have, find out by playing", "author": 2, "is_published": false, "story_uuid": "0cff5ff5-bd97-44bf-8431-02feeea92bae", "slug": "tais-secret", "access_password": "bigtai", "created_at": "2026-05-02T19:32:24.529Z", "updated_at": "2026-05-02T19:32:24.529Z"}}, {"model": "engine.node", "pk": 1, "fields": {"story": 1, "title": "The Threshold", "content": "The air here tastes of ozone and forgotten machinery. You stand at the threshold of the Great Divide, where the floor of the station gives way to a sprawling abyss of liquid data. Below, currents of static-white code pulse like the heartbeat of a dying god.\n\nTo your left, a terminal flickers with a persistent, rhythmic amber glow. It is the only light in this section of the Spire, casting your shadow long and distorted against the brutalist concrete pillars.", "node_type": "start", "x": 121.42857142857143, "y": 502.85714285714283, "correct_answer": "", "created_at": "2026-05-02T17:37:08.004Z", "updated_at": "2026-05-02T17:37:08.004Z"}}, {"model": "engine.node", "pk": 2, "fields": {"story": 1, "title": "The Dark Room", "content": "You enter the chamber. The hum of the life support systems is the only sound. Shadows stretch like fingers across the panels. A control terminal sits dormant in the center, its screen cracked but still functional.\n\nThe air is thinner here. Your suit's oxygen readout drops by 3%.", "node_type": "passage", "x": 357.922, "y": 356.312, "correct_answer": "", "created_at": "2026-05-02T17:37:08.027Z", "updated_at": "2026-05-02T17:37:08.027Z"}}, {"model": "engine.node", "pk": 3, "fields": {"story": 1, "title": "Control Panel", "content": "The terminal flickers to life. \"Oxygen levels at 12%,\" it warns in a cold, synthetic voice. You scan the interface — there's an override sequence available, but it requires a Section Key you may or may not have.\n\n\"Warning: unauthorized access will trigger station lockdown.\"", "node_type": "passage", "x": 646.0, "y": 145.0, "correct_answer": "", "created_at": "2026-05-02T17:37:08.051Z", "updated_at": "2026-05-02T17:37:08.051Z"}}, {"model": "engine.node", "pk": 4, "fields": {"story": 1, "title": "The Airlock", "content": "The door is jammed. Rust from the internal seals has fused the mechanism. You pull with everything you have, but the handle snaps clean off.\n\nBehind you, you hear the grinding of gears. The station is sealing this section. You are trapped. The oxygen counter ticks down to zero.", "node_type": "death", "x": 1085.0, "y": 379.0, "correct_answer": "", "created_at": "2026-05-02T17:37:08.067Z", "updated_at": "2026-05-02T17:37:08.067Z"}}, {"model": "engine.node", "pk": 5, "fields": {"story": 1, "title": "Emergency Pod", "content": "The override works. Emergency lights flood the corridor in pulsing red. An escape pod bay opens — Pod 7 is still operational.\n\nYou strap in. The launch sequence initiates. Through the viewport, you watch the Obsidian Spire shrink into the void, a monolith swallowed by the infinite dark.\n\nYou survived. But at what cost?", "node_type": "ending", "x": 1197.0, "y": 122.0, "correct_answer": "", "created_at": "2026-05-02T17:37:08.084Z", "updated_at": "2026-05-02T17:37:08.084Z"}}, {"model": "engine.node", "pk": 6, "fields": {"story": 1, "title": "Another end", "content": "testing", "node_type": "passage", "x": 1600.0, "y": 229.0, "correct_answer": "", "created_at": "2026-05-02T17:44:01.400Z", "updated_at": "2026-05-02T17:57:54.634Z"}}, {"model": "engine.node", "pk": 7, "fields": {"story": 1, "title": "New Node", "content": "", "node_type": "passage", "x": 1047.002, "y": 673.788, "correct_answer": "", "created_at": "2026-05-02T17:58:02.037Z", "updated_at": "2026-05-02T17:58:02.037Z"}}, {"model": "engine.node", "pk": 8, "fields": {"story": 1, "title": "New Node", "content": "", "node_type": "passage", "x": 1403.0, "y": 742.788, "correct_answer": "", "created_at": "2026-05-02T17:58:39.917Z", "updated_at": "2026-05-02T17:58:39.917Z"}}, {"model": "engine.node", "pk": 9, "fields": {"story": 1, "title": "New Node", "content": "", "node_type": "passage", "x": 660.0017242431641, "y": 604.7881927490234, "correct_answer": "", "created_at": "2026-05-02T18:02:43.721Z", "updated_at": "2026-05-02T18:02:43.721Z"}}, {"model": "engine.node", "pk": 13, "fields": {"story": 4, "title": "Start", "content": "The story begins here...", "node_type": "start", "x": 200.0, "y": 200.0, "correct_answer": "", "created_at": "2026-05-02T19:29:56.943Z", "updated_at": "2026-05-02T19:29:56.943Z"}}, {"model": "engine.node", "pk": 14, "fields": {"story": 5, "title": "access", "content": "WHAT WAS THE PASSWORD YOU USED TO ACCESS THIS GAME?", "node_type": "riddle", "x": -86.84062190112431, "y": 377.6903334469251, "correct_answer": "bigtai", "created_at": "2026-05-02T19:32:24.580Z", "updated_at": "2026-05-02T21:46:53.810Z"}}, {"model": "engine.node", "pk": 15, "fields": {"story": 5, "title": "into the room", "content": "I see, you are authorized to find my secret.\r\n\r\nYou find yourself in a room. The room felt wrong the moment you stepped in. The door behind you sealed without a sound, leaving no way back. A single table stood at the center, a small object resting on it, covered.\r\n\r\n“Authorized,” a voice echoed, calm but distant. “We’ll see.”\r\n\r\nThe air grew colder.\r\n\r\nYou took a step forward.", "node_type": "checkpoint", "x": 262.3000675367813, "y": 230.80255766297432, "correct_answer": "", "created_at": "2026-05-02T19:34:28.538Z", "updated_at": "2026-05-02T19:45:36.755Z"}}, {"model": "engine.node", "pk": 18, "fields": {"story": 5, "title": "start", "content": "My name is Taiye Babatunde. You are able to access this game because I allowed you to. To proceed, you have to answer the question.", "node_type": "start", "x": -362.63402731040867, "y": 406.5057099770569, "correct_answer": "", "created_at": "2026-05-02T19:55:40.914Z", "updated_at": "2026-05-02T21:47:03.619Z"}}, {"model": "engine.node", "pk": 19, "fields": {"story": 5, "title": "death", "content": "You shall not pass!\r\nBEGONE", "node_type": "death", "x": 206.76264971898914, "y": 533.8516586692248, "correct_answer": "", "created_at": "2026-05-02T20:05:39.900Z", "updated_at": "2026-05-02T20:05:57.419Z"}}, {"model": "engine.node", "pk": 21, "fields": {"story": 5, "title": "the table", "content": "under the cover on the table was a spherical object.\r\nYou pick up the object and examine it closely, it is cold to touch, it looks like a snow globe, in it were the letters: \r\n\"DOB?\"", "node_type": "riddle", "x": 741.2332997806561, "y": 310.0388751960072, "correct_answer": "september 6", "created_at": "2026-05-02T21:51:17.174Z", "updated_at": "2026-05-02T22:00:49.500Z"}}, {"model": "engine.node", "pk": 22, "fields": {"story": 5, "title": "Correct Choice", "content": "Ah, you seem to know me a little bit well!\r\nN", "node_type": "checkpoint", "x": 943.7370304512862, "y": 65.93912132675555, "correct_answer": "", "created_at": "2026-05-02T21:56:51.820Z", "updated_at": "2026-05-02T21:57:40.396Z"}}, {"model": "engine.node", "pk": 23, "fields": {"story": 5, "title": "wrong", "content": "You do not deserve my prize, BEGONE!", "node_type": "death", "x": 1110.466634719861, "y": 335.703847078443, "correct_answer": "", "created_at": "2026-05-02T21:58:01.108Z", "updated_at": "2026-05-02T21:59:17.396Z"}}, {"model": "engine.node", "pk": 24, "fields": {"story": 5, "title": "New Node", "content": "", "node_type": "passage", "x": 769.5765781458682, "y": 578.7086237089964, "correct_answer": "", "created_at": "2026-05-02T22:37:25.410Z", "updated_at": "2026-05-02T22:37:25.410Z"}}, {"model": "engine.choice", "pk": 1, "fields": {"source_node": 1, "target_node": 2, "choice_text": "Enter the Dark Room", "is_correct_path": null, "created_at": "2026-05-02T17:37:08.125Z"}}, {"model": "engine.choice", "pk": 2, "fields": {"source_node": 2, "target_node": 3, "choice_text": "Access the Control Panel", "is_correct_path": null, "created_at": "2026-05-02T17:37:08.142Z"}}, {"model": "engine.choice", "pk": 3, "fields": {"source_node": 2, "target_node": 4, "choice_text": "Retreat to the Airlock", "is_correct_path": null, "created_at": "2026-05-02T17:37:08.165Z"}}, {"model": "engine.choice", "pk": 4, "fields": {"source_node": 3, "target_node": 5, "choice_text": "Execute the Override Sequence", "is_correct_path": null, "created_at": "2026-05-02T17:37:08.185Z"}}, {"model": "engine.choice", "pk": 5, "fields": {"source_node": 3, "target_node": 4, "choice_text": "Abandon the Terminal and Run", "is_correct_path": null, "created_at": "2026-05-02T17:37:08.205Z"}}, {"model": "engine.choice", "pk": 6, "fields": {"source_node": 5, "target_node": 6, "choice_text": "Continue...", "is_correct_path": null, "created_at": "2026-05-02T17:58:24.037Z"}}, {"model": "engine.choice", "pk": 9, "fields": {"source_node": 18, "target_node": 14, "choice_text": "Continue...", "is_correct_path": null, "created_at": "2026-05-02T19:56:24.381Z"}}, {"model": "engine.choice", "pk": 10, "fields": {"source_node": 14, "target_node": 19, "choice_text": "Continue...", "is_correct_path": false, "created_at": "2026-05-02T20:06:13.407Z"}}, {"model": "engine.choice", "pk": 12, "fields": {"source_node": 14, "target_node": 15, "choice_text": "correct choice", "is_correct_path": true, "created_at": "2026-05-02T20:10:16.298Z"}}, {"model": "engine.choice", "pk": 13, "fields": {"source_node": 15, "target_node": 21, "choice_text": "the table", "is_correct_path": null, "created_at": "2026-05-02T21:56:17.372Z"}}, {"model": "engine.choice", "pk": 14, "fields": {"source_node": 21, "target_node": 22, "choice_text": "Continue...", "is_correct_path": true, "created_at": "2026-05-02T21:57:56.280Z"}}, {"model": "engine.choice", "pk": 15, "fields": {"source_node": 21, "target_node": 23, "choice_text": "Continue...", "is_correct_path": false, "created_at": "2026-05-02T21:59:34.105Z"}}, {"model": "engine.gamestate", "pk": 1, "fields": {"user": 1, "story": 1, "current_node": 1, "variables": {}, "started_at": "2026-05-02T17:41:53.300Z", "updated_at": "2026-05-02T18:01:16.715Z"}}, {"model": "engine.gamestate", "pk": 2, "fields": {"user": 2, "story": 1, "current_node": 6, "variables": {}, "started_at": "2026-05-02T18:47:40.626Z", "updated_at": "2026-05-02T18:47:56.812Z"}}, {"model": "engine.gamestate", "pk": 4, "fields": {"user": 2, "story": 5, "current_node": 22, "variables": {}, "started_at": "2026-05-02T19:56:50.197Z", "updated_at": "2026-05-02T22:01:01.026Z"}}]